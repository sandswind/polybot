# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kalshi (read-only scanning works without a key) ───────────────────────────
KALSHI_API_KEY=

# ── Scanner behaviour ─────────────────────────────────────────────────────────
# How often to scan (Go duration string: 30s, 1m, 5m …)
SCAN_INTERVAL=30s

# Number of markets to fetch per platform per scan
FETCH_LIMIT=200

# Minimum net profit percentage to surface an opportunity (0.02 = 2 %)
MIN_PROFIT_PCT=0.02

# Market category passed to each platform API (sports | politics | crypto)
MARKET_CATEGORY=sports

# ── Kelly position sizing ─────────────────────────────────────────────────────
# Total capital in USD (0 = Kelly disabled, no sizing shown)
BANKROLL_USD=1000

# ── Order execution (Polymarket via py-clob-client) ───────────────────────────
# true  = log orders to terminal, never submit to chain  ← safe default
# false = LIVE trading, real funds at risk
DRY_RUN=true

# Polymarket wallet credentials (required only when DRY_RUN=false)
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_CLOB_HOST=https://clob.polymarket.com

# Path to python3 binary (default: python3)
PYTHON_BIN=python3
# Directory containing order_executor.py (default: executor)
EXECUTOR_DIR=executor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kalshi (read-only scanning works without a key) ───────────────────────────
KALSHI_API_KEY=

# ── Scanner behaviour ─────────────────────────────────────────────────────────
# How often to scan (Go duration string: 30s, 1m, 5m …)
SCAN_INTERVAL=30s

# Number of markets to fetch per platform per scan
FETCH_LIMIT=200

# Minimum net profit percentage to surface an opportunity (0.02 = 2 %)
MIN_PROFIT_PCT=0.02

# Market category passed to each platform API (sports | politics | crypto)
MARKET_CATEGORY=sports
